# ── Readiness Check ──────────────────────────────────────────
location /readiness {
    access_log off;
    add_header Content-Type application/json;
    add_header Cache-Control "no-cache, no-store, must-revalidate";
    
    # These variables are injected during the Docker build stage
    return 200 '{"status": "ok", "version": "${APP_VERSION}", "release": "${REACT_APP_RELEASE}"}';
}