{
  "name": "kerrokantasi-ui",
  "version": "1.21.0",
  "license": "MIT",
  "main": "index.js",
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.16.0",
    "pnpm": ">=11.1.3"
  },
  "scripts": {
    "app:version": "echo \"$npm_package_version\"",
    "start": "pnpm update-runtime-env && vite",
    "start:e2e": "if test $NODE_MAX_MEMORY_MIB ; then node --max-old-space-size=$NODE_MAX_MEMORY_MIB pnpm start ; else pnpm start ; fi",
    "build": "vite build",
    "serve": "vite preview",
    "fetch-plugins": "node scripts/fetch_plugins.js",
    "lint": "eslint \"src/**/*.{js,jsx}\"",
    "lint:fix": "eslint \"src/**/*.{js,jsx}\" --fix",
    "test": "NODE_ENV=test pnpm update-runtime-env && vitest",
    "test:cov": "NODE_ENV=test pnpm update-runtime-env && vitest run --coverage --watch=false",
    "test:coverage": "NODE_ENV=test pnpm update-runtime-env && vitest run --coverage --watch=false",
    "test:e2e:install": "playwright install",
    "test:e2e:ci": "playwright test",
    "test:e2e:start": "playwright test",
    "test:e2e:record": "playwright codegen https://kerrokantasi.dev.hel.ninja/",
    "test:e2e:cov": "node scripts/create-baseline-coverage.mjs && nyc playwright test && pnpm run test:e2e:cov-report",
    "test:e2e:cov-report": "pnpm run merge-coverage-reports && pnpm run report-merged-coverage",
    "merge-coverage-reports": "istanbul-merge --out coverage-temp/coverage-merged.json coverage-temp/baseline-coverage.json coverage/coverage-final.json",
    "report-merged-coverage": "nyc report --report-dir=coverage --temp-dir=coverage-temp",
    "snyk-protect": "snyk protect",
    "postinstall": "if test \"$NODE_ENV\" != \"production\" ; then husky install ; fi && pnpm update-runtime-env",
    "update-runtime-env": "esrun scripts/update-runtime-env.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/City-of-Helsinki/kerrokantasi-ui.git"
  },
  "bugs": {
    "url": "https://github.com/City-of-Helsinki/kerrokantasi-ui/issues"
  },
  "dependencies": {
    "@city-of-helsinki/react-helsinki-notification-manager": "^0.1.0",
    "@draft-js-plugins/drag-n-drop": "^4.2.0",
    "@draft-js-plugins/editor": "^4.1.0",
    "@draft-js-plugins/focus": "^4.1.1",
    "@draft-js-plugins/image": "^4.1.1",
    "@draft-js-plugins/resizeable": "^5.0.4",
    "@eslint/js": "^9.25.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@sentry/react": "^9.22.0",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "@vitejs/plugin-react": "^6.0.1",
    "alertifyjs": "^1.13.1",
    "bootstrap-sass": "3.4.3",
    "browser-image-compression": "^2.0.2",
    "classnames": "^2.3.1",
    "dompurify": "^3.4.0",
    "dotenv": "^16.4.5",
    "draft-convert": "^2.1.10",
    "draft-js": "^0.11.7",
    "draft-js-export-html": "^1.4.1",
    "eslint": "^9.25.1",
    "eslint-config-prettier": "^10.1.2",
    "eslint-config-vitest-globals": "^2.0.2",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "esrun": "^3.2.26",
    "font-awesome": "^4.7.0",
    "glob": "^10.5.0",
    "globals": "^16.0.0",
    "hds-core": "^6.0.2",
    "hds-design-tokens": "^6.0.2",
    "hds-react": "^6.0.2",
    "hel-bootstrap-3": "1.0.0-beta.4",
    "history": "^5.3.0",
    "html-react-parser": "^5.2.14",
    "immutability-helper": "^3.1.1",
    "immutable": "^3.8.3",
    "leaflet": "^1.9.4",
    "leaflet-draw": "^1.0.4",
    "lodash": "^4.17.23",
    "moment": "^2.29.2",
    "normalizr": "^3.6.1",
    "proj4": "^2.7.2",
    "proj4leaflet": "^1.0.2",
    "prop-types": "^15.7.2",
    "qs": "^6.14.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-helmet-async": "^3.0.0",
    "react-intl": "^7.1.14",
    "react-leaflet": "^5.0.0",
    "react-leaflet-draw": "^0.21.0",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.17.0",
    "remark-gfm": "^4.0.0",
    "reselect": "^5.1.1",
    "sass": "^1.89.0",
    "url-parse": "^1.5.9",
    "uuid": "^14.0.0",
    "vite": "^8.0.5",
    "vite-plugin-istanbul": "^7.0.0",
    "vitest": "^4.1.2",
    "yet-another-react-lightbox": "^3.32.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.0",
    "@commitlint/config-conventional": "^19.8.0",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.3.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitest/coverage-istanbul": "^4.1.2",
    "husky": "^8.0.3",
    "istanbul-merge": "^2.0.0",
    "jsdom": "^26.1.0",
    "nyc": "^17.1.0",
    "prettier": "^3.8.1",
    "redux-mock-store": "^1.5.4",
    "simple-git": "^3.36.0",
    "vitest-fetch-mock": "^0.4.5"
  },
  "snyk": true
}
